# ============================================
# GETPRODVAL Bot — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Discord Bot Token (from discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_ID=your_channel_id_here

# OpenRouter API Key — get yours at openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Notion Integration Token (from notion.so/my-integrations)
NOTION_API_KEY=your_notion_api_key_here

# Scheduled times (UTC hour, 0–23). HKT = UTC+8
# 9:00 AM HKT = 1 UTC | 9:00 PM HKT = 13 UTC
MORNING_HOUR_UTC=1
EVENING_HOUR_UTC=13
